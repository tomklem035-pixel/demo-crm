# PostgreSQL connection string
# Local example:  postgresql://postgres:postgres@localhost:5432/demo_crm
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@host:5432/demo_crm"

# Optional: a long random string. When set, GET /api/seed?token=<this>
# will wipe and re-seed the database with mock data. Leave unset to disable.
SEED_TOKEN=""
