# PostgreSQL connection string
# Local example:  postgresql://postgres:postgres@localhost:5432/demo_crm
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@host:5432/demo_crm"

# Microsoft Azure AD (for Microsoft login + Outlook sync)
AZURE_AD_CLIENT_ID="your-azure-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_TENANT_ID="common"

# NextAuth
NEXTAUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
NEXTAUTH_URL="https://your-railway-domain.up.railway.app"

# Single-user access control
ALLOWED_EMAIL="client@example.com"
